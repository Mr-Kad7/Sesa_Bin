# Copy this file to .env and update values before running the app

# JWT secret for signing tokens
JWT_SECRET=change_me_to_a_strong_secret

# Postgres connection (optional) - example local connection
# DATABASE_URL=postgresql://postgres:password@localhost:5432/waste_management

# Alternatively set individual PG env vars used by lib/postgres.js
PGUSER=postgres
PGPASSWORD=your_db_password
PGHOST=localhost
PGPORT=5432
PGDATABASE=waste_management

# Optional fallback database used automatically when Postgres is unavailable
# SQLITE_PATH=db/local.sqlite
